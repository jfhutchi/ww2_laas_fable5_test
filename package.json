{
  "name": "operation-crossroads",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Operation Crossroads — WWII combined-arms tactical/third-person browser game (WebGPU, procedural, LAAS v2 standard)",
  "scripts": {
    "dev": "vite --port 5173 --strictPort",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --port 5174 --strictPort",
    "test": "npm run test:controls && npm run test:vehicles && npm run test:command-visuals",
    "test:controls": "tsx tools/control-regressions.ts",
    "test:vehicles": "tsx tools/vehicle-regressions.ts",
    "test:command-visuals": "tsx tools/command-visual-regressions.ts",
    "typecheck": "tsc --noEmit",
    "shoot": "tsx tools/shoot.ts",
    "compare": "tsx tools/compare.ts",
    "battery": "tsx tools/battery.ts"
  },
  "dependencies": {
    "@fontsource/barlow-condensed": "^5.2.7",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "three": "0.184.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/three": "^0.184.1",
    "@webgpu/types": "^0.1.60",
    "playwright": "^1.50.0",
    "sharp": "^0.34.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}
